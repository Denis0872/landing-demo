{
  "changeSet": "vps-runtime-hardening",
  "status": "validated",
  "server": {
    "host": "185.21.8.116",
    "port": 2222,
    "os": "Ubuntu 24.04.3 LTS"
  },
  "services": {
    "lizaAlert": {
      "enabled": true,
      "active": true,
      "port": 8080,
      "managedBy": "systemd"
    },
    "nginx": {
      "enabled": true,
      "active": true,
      "port": 80
    }
  },
  "http": {
    "localProxyStatus": 200,
    "externalStatus": 200
  },
  "sysctl": {
    "persistedFile": "/etc/sysctl.d/99-liza-alert.conf",
    "vm.swappiness": 10,
    "vm.vfs_cache_pressure": 50
  },
  "commands": [
    "systemctl is-enabled liza-alert.service nginx",
    "systemctl is-active liza-alert.service nginx",
    "curl http://localhost/api/v1/lost-cases",
    "curl http://185.21.8.116/api/v1/lost-cases"
  ]
}
